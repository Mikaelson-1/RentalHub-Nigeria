# =============================================================
# RentalHub-BOUESTI — Environment Variables
# =============================================================

# ── Database (PostgreSQL via Neon) ─────────────────────────
# Pooled URL used by the app runtime
DATABASE_URL="postgresql://USER:PASSWORD@PROJECT-pooler.REGION.aws.neon.tech:5432/DATABASE?sslmode=require&pgbouncer=true&connect_timeout=15"
# Direct URL used by Prisma db push/migrations
DIRECT_URL="postgresql://USER:PASSWORD@PROJECT.REGION.aws.neon.tech:5432/DATABASE?sslmode=require&connect_timeout=15"

# ── NextAuth.js ────────────────────────────────────────────
NEXTAUTH_SECRET="REPLACE_WITH_A_STRONG_RANDOM_SECRET_32_CHARS_MIN"
NEXTAUTH_URL="http://localhost:3000"

# ── App ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="RentalHub BOUESTI"

# ── AI Features (Google Gemini — free at aistudio.google.com) ─
GOOGLE_AI_API_KEY=""
