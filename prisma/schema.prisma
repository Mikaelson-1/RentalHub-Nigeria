// ============================================================
// RentalHub-BOUESTI — Prisma Schema
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  LANDLORD
  ADMIN
}

enum VerificationStatus {
  UNVERIFIED
  UNDER_REVIEW
  VERIFIED
  REJECTED
  SUSPENDED
}

enum PropertyStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  AWAITING_PAYMENT
  PAID
  CANCELLED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
  PARTIAL_REFUND
}

model User {
  id                 String             @id @default(cuid())
  name               String
  email              String             @unique
  password           String
  role               Role               @default(STUDENT)
  verificationStatus VerificationStatus @default(UNVERIFIED)
  emailVerified      Boolean            @default(false)
  emailVerificationSentAt DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  phoneNumber              String?
  phoneVerified            Boolean   @default(false)
  governmentIdUrl          String?
  selfieUrl                String?
  isDirectOwner            Boolean?
  landlordAware            Boolean?
  ownershipProofUrl        String?
  verificationNote         String?   @db.Text
  verificationSubmittedAt  DateTime?

  avatarUrl         String?
  aiPreScreenScore  String?
  aiPreScreenNote   String?

  properties         Property[]         @relation("LandlordProperties")
  reviewedProperties Property[]         @relation("PropertyReviews")
  bookings           Booking[]          @relation("StudentBookings")
  imageHashes        ImageHash[]
  notifications      Notification[]
  emailOtps          EmailOtp[]

  @@index([email])
  @@index([role])
  @@index([verificationStatus])
  @@map("users")
}

enum NotificationType {
  SYSTEM
  ACCOUNT
  VERIFICATION
  PROPERTY
  BOOKING
  PAYMENT
}

model Location {
  id             String     @id @default(cuid())
  name           String     @unique
  classification String     @default("Neighbourhood")
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  properties     Property[]

  @@index([classification])
  @@map("locations")
}

model Property {
  id               String         @id @default(cuid())
  title            String
  description      String         @db.Text
  price            Decimal        @db.Decimal(10, 2)
  distanceToCampus Decimal?       @db.Decimal(5, 2)
  amenities        Json           @default("[]")
  images           Json           @default("[]")
  status           PropertyStatus @default(PENDING)
  vacantUnits      Int            @default(1)
  reviewedAt       DateTime?
  reviewNote       String?        @db.Text
  aiScamFlag       Boolean        @default(false)
  aiScamReason     String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  landlordId       String
  locationId       String
  reviewedById     String?

  landlord         User           @relation("LandlordProperties", fields: [landlordId], references: [id], onDelete: Cascade)
  reviewedBy       User?          @relation("PropertyReviews", fields: [reviewedById], references: [id])
  location         Location       @relation(fields: [locationId], references: [id])
  bookings         Booking[]

  @@index([landlordId])
  @@index([locationId])
  @@index([status])
  @@index([reviewedById])
  @@index([price])
  @@map("properties")
}

model Booking {
  id              String        @id @default(cuid())
  status          BookingStatus @default(PENDING)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Snapshotted at booking time
  amount          Decimal?      @db.Decimal(10, 2)
  agencyFee       Decimal?      @db.Decimal(10, 2)
  cautionFee      Decimal?      @db.Decimal(10, 2)

  // Payment tracking
  paymentStatus   PaymentStatus @default(PENDING)
  paidAt          DateTime?
  expiresAt       DateTime?     // auto-cancel if unpaid after this

  // Tenancy
  moveInDate      DateTime?
  leaseEndDate    DateTime?

  studentId  String
  propertyId String

  student    User          @relation("StudentBookings", fields: [studentId], references: [id], onDelete: Cascade)
  property   Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  payments   Payment[]

  @@index([studentId])
  @@index([propertyId])
  @@index([status])
  @@index([paymentStatus])
  @@index([expiresAt])
  @@map("bookings")
}

model Payment {
  id             String        @id @default(cuid())
  bookingId      String
  amount         Decimal       @db.Decimal(10, 2)
  status         PaymentStatus @default(PENDING)
  paystackRef    String?       @unique
  channel        String?
  paidAt         DateTime?
  refundedAt     DateTime?
  refundAmount   Decimal?      @db.Decimal(10, 2)
  metadata       Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  booking        Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([paystackRef])
  @@index([status])
  @@map("payments")
}

model ImageHash {
  id           String   @id @default(cuid())
  hash         String
  imageUrl     String
  propertyId   String?
  uploadedById String
  flagged      Boolean  @default(false)
  flagReason   String?  @db.Text
  createdAt    DateTime @default(now())

  uploadedBy   User     @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([hash])
  @@index([uploadedById])
  @@map("image_hashes")
}

model EmailOtp {
  id        String   @id @default(cuid())
  userId    String
  email     String
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([email, createdAt])
  @@index([expiresAt])
  @@map("email_otps")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType @default(SYSTEM)
  title     String
  message   String           @db.Text
  link      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
  @@map("notifications")
}
