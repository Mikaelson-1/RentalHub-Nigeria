// ============================================================
// RentalHub-BOUESTI — Prisma Schema
// Database: PostgreSQL (Railway)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Enums ────────────────────────────────────────────────────

enum Role {
  STUDENT
  LANDLORD
  ADMIN
}

enum VerificationStatus {
  UNVERIFIED
  UNDER_REVIEW
  VERIFIED
  REJECTED
  SUSPENDED
}

enum PropertyStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

// ── Models ───────────────────────────────────────────────────

/// A platform user. Can be a student, landlord, or admin.
model User {
  id                 String             @id @default(cuid())
  name               String
  email              String             @unique
  password           String             /// Bcrypt-hashed — never store plain text
  role               Role               @default(STUDENT)
  verificationStatus VerificationStatus @default(UNVERIFIED)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  // Landlord verification fields
  phoneNumber              String?
  phoneVerified            Boolean   @default(false)
  governmentIdUrl          String?   /// Uploaded national ID / passport / driver's licence
  selfieUrl                String?   /// Photo of the person holding their ID
  isDirectOwner            Boolean?  /// true = owns the property; false = acting on landlord's behalf
  landlordAware            Boolean?  /// If not direct owner — did the landlord consent?
  ownershipProofUrl        String?   /// C of O, deed, tenancy agreement, or signed landlord letter
  verificationNote         String?   @db.Text /// Admin feedback on rejection
  verificationSubmittedAt  DateTime? /// When all docs were submitted

  // Relations
  properties         Property[]         @relation("LandlordProperties")
  reviewedProperties Property[]         @relation("PropertyReviews")
  bookings           Booking[]          @relation("StudentBookings")
  imageHashes        ImageHash[]

  @@index([email])
  @@index([role])
  @@index([verificationStatus])
  @@map("users")
}

/// A geographical area in or around Ikere-Ekiti (e.g. Uro, Afao Road).
model Location {
  id             String     @id @default(cuid())
  name           String     @unique
  /// Classification helps group areas: e.g. "Core Quarter", "Residential Estate", "Neighbourhood"
  classification String     @default("Neighbourhood")
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  // Relations
  properties     Property[]

  @@index([classification])
  @@map("locations")
}

/// A rental property listed by a landlord.
model Property {
  id               String         @id @default(cuid())
  title            String
  description      String         @db.Text
  price            Decimal        @db.Decimal(10, 2) /// Monthly rent in NGN
  distanceToCampus Decimal?       @db.Decimal(5, 2)  /// Distance in kilometres to BOUESTI main gate
  /// JSON array of amenity strings e.g. ["WiFi", "Water", "Security", "Generator"]
  amenities        Json           @default("[]")
  /// JSON array of image URL strings
  images           Json           @default("[]")
  status           PropertyStatus @default(PENDING)
  reviewedAt       DateTime?
  reviewNote       String?        @db.Text
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  // Foreign keys
  landlordId       String
  locationId       String
  reviewedById     String?

  // Relations
  landlord         User           @relation("LandlordProperties", fields: [landlordId], references: [id], onDelete: Cascade)
  reviewedBy       User?          @relation("PropertyReviews", fields: [reviewedById], references: [id])
  location         Location       @relation(fields: [locationId], references: [id])
  bookings         Booking[]

  @@index([landlordId])
  @@index([locationId])
  @@index([status])
  @@index([reviewedById])
  @@index([price])
  @@map("properties")
}

/// A booking made by a student for a property.
model Booking {
  id         String        @id @default(cuid())
  status     BookingStatus @default(PENDING)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  // Foreign keys
  studentId  String
  propertyId String

  // Relations
  student    User          @relation("StudentBookings", fields: [studentId], references: [id], onDelete: Cascade)
  property   Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([propertyId])
  @@index([status])
  @@map("bookings")
}

/// Perceptual hash of every uploaded property image — used to detect duplicates and cross-listing fraud.
model ImageHash {
  id           String   @id @default(cuid())
  hash         String               /// 64-char average-hash string
  imageUrl     String
  propertyId   String?              /// null while property is still being created
  uploadedById String
  flagged      Boolean  @default(false)
  flagReason   String?  @db.Text
  createdAt    DateTime @default(now())

  uploadedBy   User     @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([hash])
  @@index([uploadedById])
  @@map("image_hashes")
}
